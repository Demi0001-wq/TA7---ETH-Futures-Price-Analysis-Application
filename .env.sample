# ==============================================================================
# ETH PRICE MONITOR - SAMPLE ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to '.env' and fill in your actual credentials.
# The '.env' file is ignored by Git to protect your secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Binance Connectivity (Using Futures fstream)
# ------------------------------------------------------------------------------
# The WebSocket URL for Binance Futures market data.
BINANCE_WS_URL=wss://fstream.binance.com/ws

# Your Binance API credentials. 
# While basic monitoring may not require keys, advanced features or 
# high-frequency access often do.
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET_HERE

# ------------------------------------------------------------------------------
# 2. Database Configuration
# ------------------------------------------------------------------------------
# Path to the local SQLite database.
# Default: sqlite:///./data/alerts.db
DATABASE_URL=sqlite:///./data/alerts.db

# ------------------------------------------------------------------------------
# 3. Analysis & Alert Thresholds
# ------------------------------------------------------------------------------
# The percentage threshold for 'own movement' to trigger an alert.
# e.g., 1.0 = 1.0% deviation from expected BTC correlation.
ALERT_THRESHOLD_PERCENT=1.0

# The rolling window (in minutes) to check for alerts.
ALERT_WINDOW_MINUTES=60

# The lookback period (in hours) to calculate the Beta coefficient.
BETA_WINDOW_HOURS=24

# ------------------------------------------------------------------------------
# 4. Telegram Notifications (Optional)
# ------------------------------------------------------------------------------
# If you want to receive alerts on Telegram, provide your bot token and chat ID.
# Leave blank to disable Telegram alerts.
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# ------------------------------------------------------------------------------
# Security & Authentication (JWT & Dashboard)
# ------------------------------------------------------------------------------
# Admin credentials for the dashboard login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# A strong, unique secret key for signing JSON Web Tokens.
# Generate a new one for production: e.g., 'openssl rand -hex 32'
JWT_SECRET=DEVELOPMENT_ONLY_SECRET_REPLACE_FOR_PROD

# Algorithm used for JWT encoding.
JWT_ALGORITHM=HS256

# How long a dashboard session remains valid (in minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------------------------------------------
# 6. Data Encryption
# ------------------------------------------------------------------------------
# Key for encrypted state saving. 
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE
