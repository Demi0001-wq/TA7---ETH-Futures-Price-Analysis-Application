# Binance API Config (using futures fstream)
BINANCE_WS_URL=wss://fstream.binance.com/ws
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret

# Local SQLite database path
DATABASE_URL=sqlite:///./data/alerts.db

# thresholds for the monitoring math
ALERT_THRESHOLD_PERCENT=1.0
ALERT_WINDOW_MINUTES=60
BETA_WINDOW_HOURS=24

# Telegram bot info (optional)
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHAT_ID=your_chat_id

# credentials for jwt and encryption
JWT_SECRET=super_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
